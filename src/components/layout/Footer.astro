---
import { siteConfig } from '../../config';
const year = new Date().getFullYear();
---

<footer class="bg-amber-900 text-amber-100 mt-16 no-print">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- A propos -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">{siteConfig.name}</h3>
        <p class="text-amber-200 text-sm leading-relaxed">
          {siteConfig.tagline}. Outils gratuits, calculateurs et guides pratiques
          pour les auto-entrepreneurs au Maroc.
        </p>
        <p class="text-amber-300 text-sm mt-3">
          Par {siteConfig.author.name} ({siteConfig.author.credentials})
        </p>
      </div>

      <!-- Outils -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Outils Gratuits</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/calculateur-charges-ae/" class="text-amber-200 hover:text-white">Calculateur de Charges AE</a></li>
          <li><a href="/comparateur-statuts/" class="text-amber-200 hover:text-white">Comparateur de Statuts</a></li>
          <li><a href="/generateur-facture/" class="text-amber-200 hover:text-white">Generateur de Factures</a></li>
          <li><a href="/suivi-chiffre-affaires/" class="text-amber-200 hover:text-white">Suivi du Chiffre d'Affaires</a></li>
        </ul>
      </div>

      <!-- Guides -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">Guides</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/guides/inscription-auto-entrepreneur/" class="text-amber-200 hover:text-white">Guide d'Inscription AE</a></li>
          <li><a href="/guides/fiscalite-auto-entrepreneur/" class="text-amber-200 hover:text-white">Fiscalite de l'AE</a></li>
          <li><a href="/guides/passer-ae-sarl/" class="text-amber-200 hover:text-white">Passer de l'AE a la SARL</a></li>
          <li><a href="/guides/obligations-facturation/" class="text-amber-200 hover:text-white">Obligations de Facturation</a></li>
          <li><a href="/guides/cnss-auto-entrepreneur/" class="text-amber-200 hover:text-white">CNSS Auto-Entrepreneur</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-amber-800 mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-amber-300 text-sm">
        &copy; {year} {siteConfig.name}. Tous droits reserves.
      </p>
      <div class="flex gap-4 text-sm">
        <a href="/a-propos/" class="text-amber-300 hover:text-white">A propos</a>
        <a href="/mentions-legales/" class="text-amber-300 hover:text-white">Mentions legales</a>
        <a href={`mailto:${siteConfig.contact.email}`} class="text-amber-300 hover:text-white">Contact</a>
      </div>
    </div>
  </div>
</footer>
