---
import Layout from '../components/layout/Layout.astro';
---

<Layout
  title="Page Non Trouvée (404) - Auto-Entrepreneur au Maroc"
  description="La page que vous recherchez n'existe pas ou a été déplacée. Retournez à l'accueil du guide auto-entrepreneur au Maroc pour trouver ce que vous cherchez."
  noindex={true}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-extrabold text-amber-300 mb-4">404</p>
    <h1 class="text-3xl font-extrabold text-amber-900 mb-4">
      Page non trouvée
    </h1>
    <p class="text-gray-600 mb-8 text-lg">
      La page que vous recherchez n'existe pas ou a été déplacée.
      Vérifiez l'URL ou retournez à l'accueil.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/" class="btn-primary">
        Retour à l'accueil
      </a>
      <a href="/calculateur-charges-ae/" class="btn-secondary">
        Calculateur de charges
      </a>
    </div>
  </div>
</Layout>
