---
import Layout from '../components/layout/Layout.astro';
import { siteConfig } from '../config';
import { getFAQSchema, getBreadcrumbSchema } from '../lib/seo';

const faqData = [
  {
    question: "Qu'est-ce que le statut auto-entrepreneur au Maroc ?",
    answer: "Le statut auto-entrepreneur au Maroc, créé par la Loi 114-13, est un régime juridique simplifié permettant aux personnes physiques d'exercer une activité professionnelle de manière indépendante. Il offre une fiscalité avantageuse (1 à 2% du chiffre d'affaires), une création en 48h en ligne sur ae.gov.ma, et une comptabilité simplifiée. Ce statut est idéal pour les freelances, artisans, commerçants et prestataires de services dont le CA reste sous les seuils légaux.",
  },
  {
    question: "Quels sont les plafonds de chiffre d'affaires pour un auto-entrepreneur ?",
    answer: "Les plafonds annuels sont de 500 000 DH pour les activités commerciales, industrielles et artisanales, et de 200 000 DH pour les prestations de services. Si ces seuils sont dépassés durant 2 années consécutives, l'auto-entrepreneur doit obligatoirement passer au régime réel (SARL ou autre forme juridique).",
  },
  {
    question: "Comment s'inscrire comme auto-entrepreneur au Maroc ?",
    answer: "L'inscription se fait en ligne sur la plateforme ae.gov.ma. Vous aurez besoin d'une copie de votre CIN, d'un certificat de résidence de moins de 3 mois, et d'une photo d'identité. Le processus prend environ 48 heures pour obtenir votre certificat d'inscription et votre numéro ICE (Identifiant Commun de l'Entreprise).",
  },
  {
    question: "Quelles sont les obligations fiscales d'un auto-entrepreneur ?",
    answer: "L'auto-entrepreneur doit effectuer une déclaration trimestrielle de son chiffre d'affaires (même si CA = 0), payer l'IR forfaitaire trimestriellement (1% pour les activités commerciales, 2% pour les services), cotiser à l'AMO (300 DH/trimestre), tenir un registre des achats et ventes, et établir des factures avec les mentions obligatoires dont le numéro ICE.",
  },
  {
    question: "Quand faut-il passer de l'auto-entrepreneur à la SARL ?",
    answer: "Le passage à la SARL devient obligatoire si vous dépassez les seuils de CA (200 000 ou 500 000 DH) pendant 2 années consécutives. Il est également recommandé si vous avez besoin d'une meilleure protection sociale, d'une responsabilité limitée, de la possibilité de déduire vos charges professionnelles, ou si vous souhaitez donner plus de crédibilité à votre activité auprès des banques et grands clients.",
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    getBreadcrumbSchema([{ name: 'Accueil', url: siteConfig.url + '/' }]),
    getFAQSchema(faqData),
  ],
};
---

<Layout
  title="Auto-Entrepreneur Maroc : Guide Complet et Outils 2026"
  description="Guide complet de l'auto-entrepreneur au Maroc : calculateur de charges, comparateur de statuts, générateur de factures. Outils gratuits et guides pratiques."
  schema={schema}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-amber-600 via-amber-700 to-amber-800 text-white py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight text-white mb-6">
          Auto-Entrepreneur au Maroc : Guide Complet et Outils Gratuits
        </h1>
        <p class="text-xl sm:text-2xl text-amber-100 mb-8 leading-relaxed">
          Tout ce que vous devez savoir pour créer, gérer et développer votre activité d'auto-entrepreneur au Maroc.
          Calculateurs, guides et outils pratiques 100% gratuits.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/calculateur-charges-ae/" class="inline-flex items-center px-6 py-3 bg-white text-amber-800 font-bold rounded-lg hover:bg-amber-50 transition-all hover:no-underline">
            Calculer mes charges
          </a>
          <a href="/guides/inscription-auto-entrepreneur/" class="inline-flex items-center px-6 py-3 border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-all hover:no-underline">
            Guide d'inscription
          </a>
        </div>
        <p class="text-amber-200 text-sm mt-6">
          Par {siteConfig.author.name} ({siteConfig.author.credentials}) &middot; Mis à jour en 2026
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="py-12 bg-white border-b border-amber-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div class="p-6">
          <p class="text-3xl font-extrabold text-amber-700">1-2%</p>
          <p class="text-gray-600 mt-1">Taux d'imposition forfaitaire</p>
        </div>
        <div class="p-6">
          <p class="text-3xl font-extrabold text-amber-700">48h</p>
          <p class="text-gray-600 mt-1">Délai de création en ligne</p>
        </div>
        <div class="p-6">
          <p class="text-3xl font-extrabold text-amber-700">0 DH</p>
          <p class="text-gray-600 mt-1">Capital minimum requis</p>
        </div>
        <div class="p-6">
          <p class="text-3xl font-extrabold text-amber-700">300 DH</p>
          <p class="text-gray-600 mt-1">AMO par trimestre</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Outils Cards -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-amber-900 text-center mb-4">Outils Gratuits pour Auto-Entrepreneurs</h2>
      <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        Des calculateurs et outils pratiques pour gérer votre activité d'auto-entrepreneur en toute sérénité.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Calculateur -->
        <a href="/calculateur-charges-ae/" class="card group hover:no-underline">
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4 text-2xl group-hover:bg-amber-200 transition-colors">
            <span aria-hidden="true">&#9998;</span>
          </div>
          <h3 class="text-lg font-bold text-amber-900 mb-2">Calculateur de Charges</h3>
          <p class="text-gray-600 text-sm">
            Calculez votre IR forfaitaire, AMO et revenu net en fonction de votre chiffre d'affaires mensuel ou trimestriel.
          </p>
        </a>

        <!-- Comparateur -->
        <a href="/comparateur-statuts/" class="card group hover:no-underline">
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4 text-2xl group-hover:bg-amber-200 transition-colors">
            <span aria-hidden="true">&#9878;</span>
          </div>
          <h3 class="text-lg font-bold text-amber-900 mb-2">Comparateur de Statuts</h3>
          <p class="text-gray-600 text-sm">
            Comparez Auto-Entrepreneur, SARL et SAS : impôts, charges sociales, net final et complexité administrative.
          </p>
        </a>

        <!-- Factures -->
        <a href="/generateur-facture/" class="card group hover:no-underline">
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4 text-2xl group-hover:bg-amber-200 transition-colors">
            <span aria-hidden="true">&#9993;</span>
          </div>
          <h3 class="text-lg font-bold text-amber-900 mb-2">Générateur de Factures</h3>
          <p class="text-gray-600 text-sm">
            Créez des factures conformes avec toutes les mentions obligatoires (ICE, exonération TVA) et imprimez-les.
          </p>
        </a>

        <!-- Suivi CA -->
        <a href="/suivi-chiffre-affaires/" class="card group hover:no-underline">
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4 text-2xl group-hover:bg-amber-200 transition-colors">
            <span aria-hidden="true">&#9632;</span>
          </div>
          <h3 class="text-lg font-bold text-amber-900 mb-2">Suivi du CA</h3>
          <p class="text-gray-600 text-sm">
            Suivez votre chiffre d'affaires mois par mois, visualisez votre progression et anticipez le dépassement du seuil.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- 5 Étapes -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-amber-900 text-center mb-12">
        Devenir Auto-Entrepreneur en 5 Étapes
      </h2>

      <div class="relative">
        <!-- Timeline Line -->
        <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-amber-300 transform -translate-x-1/2"></div>

        <div class="space-y-8 lg:space-y-12">
          <!-- Step 1 -->
          <div class="lg:flex items-center gap-8">
            <div class="lg:w-1/2 lg:text-right lg:pr-8">
              <div class="card">
                <span class="inline-block bg-amber-600 text-white text-sm font-bold w-8 h-8 rounded-full flex items-center justify-center mb-3">1</span>
                <h3 class="text-lg font-bold text-amber-900">Vérifiez votre éligibilité</h3>
                <p class="text-gray-600 text-sm mt-2">
                  Assurez-vous que votre activité est compatible avec le statut AE et que votre CA prévisionnel
                  reste sous les seuils (200 000 DH pour les services, 500 000 DH pour le commerce).
                </p>
              </div>
            </div>
            <div class="hidden lg:block w-4 h-4 bg-amber-600 rounded-full border-4 border-white shadow-md z-10 absolute left-1/2 transform -translate-x-1/2"></div>
            <div class="lg:w-1/2"></div>
          </div>

          <!-- Step 2 -->
          <div class="lg:flex items-center gap-8">
            <div class="lg:w-1/2"></div>
            <div class="lg:w-1/2 lg:pl-8">
              <div class="card">
                <span class="inline-block bg-amber-600 text-white text-sm font-bold w-8 h-8 rounded-full flex items-center justify-center mb-3">2</span>
                <h3 class="text-lg font-bold text-amber-900">Préparez vos documents</h3>
                <p class="text-gray-600 text-sm mt-2">
                  Réunissez votre CIN (Carte d'Identité Nationale), un certificat de résidence de moins de 3 mois
                  et une photo d'identité récente au format numérique.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="lg:flex items-center gap-8">
            <div class="lg:w-1/2 lg:text-right lg:pr-8">
              <div class="card">
                <span class="inline-block bg-amber-600 text-white text-sm font-bold w-8 h-8 rounded-full flex items-center justify-center mb-3">3</span>
                <h3 class="text-lg font-bold text-amber-900">Inscrivez-vous sur ae.gov.ma</h3>
                <p class="text-gray-600 text-sm mt-2">
                  Rendez-vous sur le portail officiel ae.gov.ma, créez votre compte, remplissez le formulaire
                  d'inscription et téléchargez vos documents. Le processus est entièrement en ligne.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2"></div>
          </div>

          <!-- Step 4 -->
          <div class="lg:flex items-center gap-8">
            <div class="lg:w-1/2"></div>
            <div class="lg:w-1/2 lg:pl-8">
              <div class="card">
                <span class="inline-block bg-amber-600 text-white text-sm font-bold w-8 h-8 rounded-full flex items-center justify-center mb-3">4</span>
                <h3 class="text-lg font-bold text-amber-900">Recevez votre certificat</h3>
                <p class="text-gray-600 text-sm mt-2">
                  En environ 48 heures, vous recevrez votre certificat d'inscription et votre numéro ICE
                  (Identifiant Commun de l'Entreprise). Vous pouvez alors commencer à facturer.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="lg:flex items-center gap-8">
            <div class="lg:w-1/2 lg:text-right lg:pr-8">
              <div class="card">
                <span class="inline-block bg-amber-600 text-white text-sm font-bold w-8 h-8 rounded-full flex items-center justify-center mb-3">5</span>
                <h3 class="text-lg font-bold text-amber-900">Gérez votre activité</h3>
                <p class="text-gray-600 text-sm mt-2">
                  Déclarez votre CA trimestriellement, payez votre IR et AMO, tenez votre registre des achats/ventes,
                  et émettez des factures conformes. Utilisez nos outils gratuits pour simplifier tout cela.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Content Section -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose">
      <h2>Guide Complet de l'Auto-Entrepreneur au Maroc</h2>

      <p>
        Le statut d'auto-entrepreneur au Maroc, instauré par la <strong>Loi 114-13</strong>, représente une avancée majeure
        pour l'entrepreneuriat au Maroc. Ce régime simplifié permet à toute personne physique d'exercer une activité
        professionnelle indépendante avec un minimum de formalités administratives et une fiscalité extrêmement avantageuse.
        Depuis sa mise en place, des centaines de milliers de Marocains ont adopté ce statut pour lancer leur activité.
      </p>

      <h3>Qu'est-ce que le statut auto-entrepreneur ?</h3>

      <p>
        L'auto-entrepreneur est une personne physique qui exerce, à titre individuel, une activité industrielle, commerciale,
        artisanale ou de prestation de services. Ce statut se distingue par sa simplicité : pas de capital minimum, pas de
        comptabilité complexe, et une création qui se fait entièrement en ligne en 48 heures.
      </p>

      <p>
        L'un des principaux avantages est la <strong>fiscalité forfaitaire</strong>. Au lieu de calculer un bénéfice net
        imposable comme dans une SARL, l'auto-entrepreneur paie simplement un pourcentage de son chiffre d'affaires :
        <strong>1% pour les activités commerciales, industrielles et artisanales</strong>, et <strong>2% pour les
        prestations de services</strong>. Ce système est d'une simplicité remarquable et permet de connaître immédiatement
        le montant de ses impôts.
      </p>

      <h3>Les plafonds de chiffre d'affaires</h3>

      <p>
        Le statut auto-entrepreneur est soumis à des plafonds de chiffre d'affaires annuel. Pour les <strong>activités
        commerciales, industrielles et artisanales</strong>, le plafond est fixé à <strong>500 000 DH par an</strong>.
        Pour les <strong>prestations de services</strong>, il est de <strong>200 000 DH par an</strong>.
      </p>

      <p>
        Il est crucial de surveiller ces seuils car leur dépassement pendant deux années consécutives entraîne le
        passage obligatoire au régime réel. Notre <a href="/suivi-chiffre-affaires/">outil de suivi du CA</a> vous
        permet de suivre votre progression tout au long de l'année.
      </p>

      <h3>Les charges de l'auto-entrepreneur</h3>

      <p>
        Les charges de l'auto-entrepreneur marocain sont parmi les plus basses du monde :
      </p>

      <ul>
        <li><strong>Impôt sur le revenu (IR) forfaitaire</strong> : 1% du CA pour les activités commerciales, 2% pour les services</li>
        <li><strong>Cotisation AMO (Assurance Maladie Obligatoire)</strong> : 300 DH par trimestre, soit 1 200 DH par an</li>
      </ul>

      <p>
        Cela signifie que pour un prestataire de services avec un CA de 10 000 DH par mois, les charges totales
        (IR + AMO) ne représentent qu'environ 3 200 DH par an, soit un taux effectif de seulement 2,67% du CA annuel.
        C'est un avantage considérable par rapport aux autres formes juridiques.
      </p>

      <h3>Les obligations de l'auto-entrepreneur</h3>

      <p>
        Malgré la simplicité du statut, l'auto-entrepreneur a certaines obligations :
      </p>

      <ul>
        <li><strong>Déclaration trimestrielle du CA</strong> : Même si votre CA est de 0, vous devez déclarer</li>
        <li><strong>Paiement trimestriel de l'IR</strong> : Calculé sur le CA déclaré</li>
        <li><strong>Paiement de l'AMO</strong> : 300 DH chaque trimestre</li>
        <li><strong>Tenue d'un registre</strong> : Un livre journal des achats et ventes</li>
        <li><strong>Facturation conforme</strong> : Avec toutes les mentions obligatoires (ICE, exonération TVA, etc.)</li>
      </ul>

      <h3>L'exonération de TVA</h3>

      <p>
        L'auto-entrepreneur est <strong>exonéré de TVA</strong>. Cela signifie que vous ne facturez pas de TVA à vos
        clients et vous ne pouvez pas récupérer la TVA sur vos achats. Chaque facture doit porter la mention
        "Exonéré de TVA". Cette exonération simplifie considérablement la gestion comptable mais peut être un
        inconvénient si vos fournisseurs sont assujettis à la TVA.
      </p>

      <h3>Auto-Entrepreneur vs SARL : que choisir ?</h3>

      <p>
        Le choix entre auto-entrepreneur et SARL dépend de votre situation. L'AE est idéal pour démarrer une activité
        avec un CA modeste et des charges faibles. La SARL convient mieux pour des CA élevés, quand vous avez besoin
        de déduire des charges importantes ou quand vous souhaitez une meilleure protection juridique et sociale.
      </p>

      <p>
        Notre <a href="/comparateur-statuts/">comparateur de statuts</a> vous permet de simuler les deux scénarios
        avec vos chiffres réels pour prendre la meilleure décision.
      </p>

      <h3>Comment s'inscrire ?</h3>

      <p>
        L'inscription se fait sur <strong>ae.gov.ma</strong>, la plateforme officielle. Vous aurez besoin de votre CIN,
        d'un certificat de résidence récent et d'une photo d'identité. Le processus est rapide et vous obtenez votre
        certificat d'inscription et votre numéro ICE en environ 48 heures. Consultez notre
        <a href="/guides/inscription-auto-entrepreneur/">guide d'inscription détaillé</a> pour toutes les étapes.
      </p>

      <h3>Pourquoi utiliser nos outils ?</h3>

      <p>
        Nos outils ont été conçus spécifiquement pour les auto-entrepreneurs marocains. Ils sont basés sur les
        taux et seuils officiels 2026 et sont régulièrement mis à jour. Que vous ayez besoin de
        <a href="/calculateur-charges-ae/">calculer vos charges</a>,
        <a href="/generateur-facture/">générer une facture conforme</a>,
        <a href="/comparateur-statuts/">comparer les statuts juridiques</a> ou
        <a href="/suivi-chiffre-affaires/">suivre votre CA</a>, tout est gratuit et disponible en ligne.
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-amber-900 text-center mb-12">
        Questions Fréquentes
      </h2>

      <div class="space-y-4">
        {faqData.map((faq, i) => (
          <details class="card group" id={`faq-${i}`}>
            <summary class="cursor-pointer list-none flex items-center justify-between">
              <h3 class="text-lg font-bold text-amber-900 pr-4">{faq.question}</h3>
              <span class="text-amber-500 transform group-open:rotate-45 transition-transform text-xl flex-shrink-0">+</span>
            </summary>
            <p class="text-gray-700 mt-4 leading-relaxed">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides Section -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-amber-900 text-center mb-12">
        Guides Pratiques
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/guides/inscription-auto-entrepreneur/" class="card group hover:no-underline">
          <h3 class="text-lg font-bold text-amber-900 mb-2 group-hover:text-amber-700">Guide d'Inscription</h3>
          <p class="text-gray-600 text-sm">Étapes détaillées pour s'inscrire sur ae.gov.ma, documents nécessaires et pièges à éviter.</p>
        </a>
        <a href="/guides/fiscalite-auto-entrepreneur/" class="card group hover:no-underline">
          <h3 class="text-lg font-bold text-amber-900 mb-2 group-hover:text-amber-700">Fiscalité de l'AE</h3>
          <p class="text-gray-600 text-sm">Comprendre l'IR forfaitaire, la déclaration trimestrielle et les pénalités de retard.</p>
        </a>
        <a href="/guides/passer-ae-sarl/" class="card group hover:no-underline">
          <h3 class="text-lg font-bold text-amber-900 mb-2 group-hover:text-amber-700">Passer de l'AE à la SARL</h3>
          <p class="text-gray-600 text-sm">Quand et comment transitionner vers la SARL, avantages et inconvénients.</p>
        </a>
        <a href="/guides/obligations-facturation/" class="card group hover:no-underline">
          <h3 class="text-lg font-bold text-amber-900 mb-2 group-hover:text-amber-700">Obligations de Facturation</h3>
          <p class="text-gray-600 text-sm">Mentions obligatoires, ICE, registre des ventes et conformité légale.</p>
        </a>
        <a href="/guides/cnss-auto-entrepreneur/" class="card group hover:no-underline">
          <h3 class="text-lg font-bold text-amber-900 mb-2 group-hover:text-amber-700">CNSS Auto-Entrepreneur</h3>
          <p class="text-gray-600 text-sm">Couverture AMO, adhésion volontaire et droits sociaux de l'AE.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-amber-600 to-amber-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">
        Prêt à calculer vos charges ?
      </h2>
      <p class="text-amber-100 text-lg mb-8">
        Utilisez notre calculateur gratuit pour estimer votre IR, AMO et revenu net en quelques secondes.
      </p>
      <a href="/calculateur-charges-ae/" class="inline-flex items-center px-8 py-4 bg-white text-amber-800 font-bold rounded-lg text-lg hover:bg-amber-50 transition-all hover:no-underline">
        Lancer le calculateur
      </a>
    </div>
  </section>
</Layout>
